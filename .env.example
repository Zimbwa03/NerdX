# =============================================================================
# NerdX — environment variables
# Copy to `.env` in this directory. Never commit real `.env` files.
# Verify what is set (without printing secrets):  python scripts/check_env.py
# =============================================================================

# -----------------------------------------------------------------------------
# CRITICAL — Supabase (mobile API, credits, MAIC AI Classroom, schools, etc.)
# Without URL + service role, external_db logs a warning and writes fail.
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -----------------------------------------------------------------------------
# SECURITY — JWT signing for /api/mobile/* (change in production)
# If unset, api/mobile.py falls back to a weak default — not safe for production.
# -----------------------------------------------------------------------------
JWT_SECRET=generate_a_long_random_string_here

# -----------------------------------------------------------------------------
# AI — Vertex / Gemini (PRIMARY path for many features including MAIC classroom)
# Set ONE credential path: file OR inline JSON (not both required).
# -----------------------------------------------------------------------------
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
# Option A: path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# Option B: entire JSON as one line (some hosts prefer this)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# -----------------------------------------------------------------------------
# AI — API keys (fallbacks / non-Vertex paths)
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
GEMINI_API_KEY=your_gemini_api_key_here
# Some modules also read:
# GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# App / DB
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///nerdx_quiz.db
BASE_URL=https://your-public-api-host.example.com

# School portal: daily credit reset timezone (e.g. Africa/Harare, UTC)
SCHOOL_CREDITS_RESET_TIMEZONE=Africa/Harare

# -----------------------------------------------------------------------------
# OPTIONAL — Twilio (WhatsApp)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# -----------------------------------------------------------------------------
# OPTIONAL — EcoCash / other
# -----------------------------------------------------------------------------
ECOCASH_API_KEY=
ECOCASH_MERCHANT_CODE=
DESMOS_API_KEY=
