# =============================================================================
# NerdX — Environment Variables Template
# =============================================================================
# Copy this file to `.env` in the project root:
#   cp .env.example .env
# Fill in your actual values. NEVER commit the real `.env` to git.
# Verify variables are set (without printing secrets): python scripts/check_env.py
# =============================================================================

# =============================================================================
# === Supabase (PostgreSQL database, auth, storage) ===
# =============================================================================
# Your Supabase project URL (found in Project Settings > API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon/public key — safe for client-side, limited RLS permissions
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Alias used by some modules
SUPABASE_KEY=your_supabase_anon_key_here

# Service role key — full database access, server-side only, never expose publicly
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Direct PostgreSQL connection string (for SQLAlchemy / admin panels)
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-region.pooler.supabase.com:6543/postgres
# Alias used by some modules
SUPABASE_DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-region.pooler.supabase.com:6543/postgres

# =============================================================================
# === AI Configuration — Google Vertex AI / Gemini ===
# =============================================================================
# Set to True to use Vertex AI (production). Set to False to use Gemini API key directly.
GOOGLE_GENAI_USE_VERTEXAI=True

# Your Google Cloud project ID (e.g. gen-lang-client-1234567890)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Vertex AI region. Use a real region like us-central1 (NOT "global" for live features)
GOOGLE_CLOUD_LOCATION=us-central1

# Option A (recommended on Render): paste full service account JSON as a single env var value
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...@....iam.gserviceaccount.com"}

# Option B: path to service account JSON file (preferred for local dev)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Gemini model names
VERTEX_GEMINI_TEXT_MODEL=gemini-2.5-flash

# =============================================================================
# === AI Configuration — Other APIs ===
# =============================================================================
# Direct Gemini API key (fallback / non-Vertex path)
GEMINI_API_KEY=your_gemini_api_key_here
# Alias used by some modules
# GOOGLE_API_KEY=your_gemini_api_key_here

# DeepSeek API (used for certain math and reasoning tasks)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# =============================================================================
# === Twilio (WhatsApp bot) ===
# =============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =============================================================================
# === WhatsApp Business API (alternative/direct integration) ===
# =============================================================================
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=your_custom_webhook_verify_token_here

# =============================================================================
# === Payments — EcoCash ===
# =============================================================================
ECOCASH_API_KEY=
ECOCASH_MERCHANT_CODE=

# =============================================================================
# === Storage / Media ===
# =============================================================================
# ImgBB API key (used for hosting generated graph/diagram images)
IMGBB_API_KEY=your_imgbb_api_key_here

# Desmos API key (for graph embeds)
DESMOS_API_KEY=

# =============================================================================
# === Application Configuration ===
# =============================================================================
# Public-facing base URL of this backend API
BASE_URL=https://your-public-api-host.example.com

# Render sets this automatically on deploy — used for self-referencing URLs
RENDER_EXTERNAL_URL=https://nerdx.co.zw

# Public URLs referenced by mobile/web apps
APP_URL=https://nerdx.co.zw
WEB_URL=https://nerdx.co.zw

# Flask/JWT session signing secret — generate a long random string for production
JWT_SECRET=generate_a_long_random_string_here
SESSION_SECRET=your_session_secret_here

# School portal: daily credit reset timezone
SCHOOL_CREDITS_RESET_TIMEZONE=Africa/Harare

# Maintenance mode — set to 'true' to enable
MAINTENANCE_MODE=false

# =============================================================================
# === Feature Flags ===
# =============================================================================
# Enable Manim-based animated math/science rendering (requires extra deps)
ENABLE_MANIM_RENDERING=true

# Use ZIMSEC beta math prompts (experimental)
USE_ZIMSEC_BETA_MATH_PROMPTS=false
