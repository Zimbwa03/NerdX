# API origin (Flask). Use empty string for local Vite dev (proxies /api to port 5000).
VITE_API_BASE_URL=https://nerdx.co.zw

# Canonical site origin for share links (school portal, teacher login, referrals, OAuth redirects in prod builds).
# Leave unset during local dev to use the current browser origin (e.g. http://localhost:5173).
VITE_PUBLIC_SITE_URL=https://nerdx.co.zw

VITE_SUPABASE_URL=https://lzteiewcvxoazqfxfjgg.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# NerdX Live (voice agent) WebSocket base URL (no trailing /ws/nerdx-live).
VITE_NERDX_LIVE_WS_URL=wss://nerdx.co.zw

# NerdX Live (voice agent) WebRTC signalling base URL (no trailing /rtc/nerdx-live/offer).
VITE_NERDX_LIVE_RTC_URL=https://nerdx.co.zw

# Optional ICE servers as JSON (RTCIceServer[]). If omitted, the client uses public STUN by default.
# Example (TURN strongly recommended for production):
# VITE_NERDX_LIVE_ICE_SERVERS=[{\"urls\":\"stun:stun.l.google.com:19302\"},{\"urls\":\"turn:turn.example.com:3478\",\"username\":\"user\",\"credential\":\"pass\"}]

# Supabase: Add these redirect URLs in Dashboard > Authentication > URL Configuration:
# - http://localhost:5173/reset-password (dev)
# - http://localhost:5173/auth/callback (dev)
# - https://nerdx.co.zw/reset-password (prod)
# - https://nerdx.co.zw/auth/callback (prod)
