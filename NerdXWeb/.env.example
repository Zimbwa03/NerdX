# API origin (Flask).
# — Empty: local Vite proxies /api, /admin, /health to http://localhost:5000
# — Remote: your Render service (no trailing slash)
VITE_API_BASE_URL=https://nerdx.onrender.com

# Canonical site for share links / OAuth when you need a fixed origin (production builds).
# Leave unset or blank during local dev so the app uses http://localhost:5173 (see getPublicSiteOrigin).
# VITE_PUBLIC_SITE_URL=https://nerdx.co.zw

VITE_SUPABASE_URL=https://lzteiewcvxoazqfxfjgg.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# NerdX Live (voice): same host as API if the Render app serves those routes; otherwise point at prod.
VITE_NERDX_LIVE_WS_URL=wss://nerdx.onrender.com
VITE_NERDX_LIVE_RTC_URL=https://nerdx.onrender.com

# Optional ICE servers as JSON (RTCIceServer[]). If omitted, the client uses public STUN by default.
# Example (TURN strongly recommended for production):
# VITE_NERDX_LIVE_ICE_SERVERS=[{\"urls\":\"stun:stun.l.google.com:19302\"},{\"urls\":\"turn:turn.example.com:3478\",\"username\":\"user\",\"credential\":\"pass\"}]

# Supabase: add redirect URLs in Dashboard > Authentication > URL Configuration:
# - http://localhost:5173/reset-password (dev)
# - http://localhost:5173/auth/callback (dev)
# - https://nerdx.co.zw/reset-password (prod)
# - https://nerdx.co.zw/auth/callback (prod)
