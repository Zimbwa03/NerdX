# =============================================================================
# NerdX — .gitignore
# =============================================================================

# =============================================================================
# Environment Variables — NEVER COMMIT THESE
# =============================================================================
.env
.env.local
.env.*.local
.env.production
.env.staging

# =============================================================================
# Python
# =============================================================================
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# =============================================================================
# Database & Runtime Artifacts
# =============================================================================
# SQLite databases
*.db
*.sqlite
*.sqlite3

# Flask instance path (runtime SQLite, session files)
instance/

# ChromaDB vector store (runtime artifact — regenerated from source data)
chroma_db/

# Temporary audio files generated at runtime
temp_audio/

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
debug.log
pip-log.txt

# =============================================================================
# Test & Coverage Artifacts
# =============================================================================
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.mypy_cache/

# =============================================================================
# Secrets & Credentials
# =============================================================================
credentials.json
service-account*.json
credentials/
*.pem
*.key
*.crt
*.p12
*.jks
*.keystore
local_config.py

# =============================================================================
# Node / JavaScript / Frontend
# =============================================================================
node_modules/
.expo/
.expo-shared/
.next/
.cache/
# Note: dist/ and build/ are NOT ignored here because Dockerfile copies NerdXWeb/dist

# =============================================================================
# Mobile — Android
# =============================================================================
android/.gradle/
android/app/build/
android/local.properties
*.apk
*.aab

# =============================================================================
# Static generated files (runtime)
# =============================================================================
static/graphs/*.png
static/pdfs/*.pdf

# =============================================================================
# IDE & OS
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================================================
# Temporary & Backup Files
# =============================================================================
*.tmp
*.temp
*.bak
*.backup
*.orig
temp/

# =============================================================================
# Project-specific holding areas (review before deleting permanently)
# =============================================================================
_archive/
attached_assets/
